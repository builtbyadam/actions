# Dependencies
node_modules/
.pnp/
.pnp.js

# IMPORTANT: do NOT ignore dist/
# JavaScript actions run the COMMITTED bundle, so dist/ must be tracked.

# Build / coverage caches
*.tsbuildinfo
.cache/
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example

# Python (for Python-based actions)
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp